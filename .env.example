# ─────────────────────────────────────────────────────────────────────────────
# NexusFlow — Environment Variable Template
#
# Copy this file to .env and fill in real values before running the app:
#   cp .env.example .env
#
# .env is listed in .gitignore — never commit real secrets to source control.
# ─────────────────────────────────────────────────────────────────────────────


# ── App ───────────────────────────────────────────────────────────────────────

APP_NAME=NexusFlow
APP_VERSION=1.0.0
# Set to true to enable verbose debug output. Never use true in production.
DEBUG=false


# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required — app will not start without this).
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<database>

DATABASE_URL=postgresql+psycopg2://nexusflow_user:your_password@localhost:5432/nexusflow_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10


# ── Agents ────────────────────────────────────────────────────────────────────
# Default LLM model used by all agents unless overridden per-agent.
# Accepted values: claude-sonnet, claude-opus, claude-haiku

DEFAULT_MODEL=claude-sonnet
# Number of times an agent will retry a failed LLM call before giving up.
MAX_RETRIES=3
# Maximum seconds a single agent task is allowed to run before timing out.
TASK_TIMEOUT=300


# ── Tools ─────────────────────────────────────────────────────────────────────
# API key for the web search tool. Leave blank to disable web search.
# Obtain a key from your search provider dashboard.

WEB_SEARCH_API_KEY=your_web_search_api_key_here
MAX_SEARCH_RESULTS=10


# ── LLM ───────────────────────────────────────────────────────────────────────
# Anthropic API key for calling Claude models via APIConnectorTool.
# Obtain from https://console.anthropic.com/

ANTHROPIC_API_KEY=your_anthropic_api_key_here
